<?xml version="1.0" encoding="utf-8"?>
<robot name="IRB140">

  <!-- Project convention: all robot origin RPY values and angular limits are
       authored in degrees. The runtime kinematics path converts them to
       radians before handing the model to urdfdom/KDL. -->

  <!-- Links -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_BASE.stl"/></geometry>
    </visual>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 -352" rpy="0 0 0"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_LINK1.STL"/></geometry>
    </visual>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="352 70 0" rpy="-90 0 90"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_LINK2.STL"/></geometry>
    </visual>
  </link>

  <link name="link3">
    <visual>
      <origin xyz="712 70 0" rpy="-90 0 90"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_LINK3.STL"/></geometry>
    </visual>
  </link>

  <link name="link4">
    <visual>
      <origin xyz="712 0 -450" rpy="0 -90 0"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_LINK4.STL"/></geometry>
    </visual>
  </link>

  <link name="link5">
    <visual>
      <origin xyz="712 450 0" rpy="-90 0 90"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_LINK5.STL"/></geometry>
    </visual>
  </link>

  <link name="link6">
    <visual>
      <origin xyz="712 0 -450" rpy="0 -90 0"/>
      <geometry><mesh filename="geometry/IRB140_M2004C_LINK6.STL"/></geometry>
    </visual>
  </link>

  <link name="tool_mount"/>

  <!-- Joints (Craig DH → URDF: xyz=(a,0,d), rpy=(alpha,0,0)) -->

  <!-- J1: alpha=0,  a=0,    d=352, offset=0   -->
  <joint name="joint1" type="revolute" offset_deg="0">
    <parent link="base_link"/><child link="link1"/>
    <origin xyz="0 0 352" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-180" upper="180" effort="0" velocity="0"/>
  </joint>

  <!-- J2: alpha=-90, a=70,  d=0,   offset=90  -->
  <joint name="joint2" type="revolute" offset_deg="90">
    <parent link="link1"/><child link="link2"/>
    <origin xyz="70 0 0" rpy="-90 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-90" upper="110" effort="0" velocity="0"/>
  </joint>

  <!-- J3: alpha=0,  a=-360, d=0,   offset=0   -->
  <joint name="joint3" type="revolute" offset_deg="0">
    <parent link="link2"/><child link="link3"/>
    <origin xyz="-360 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-230" upper="50" effort="0" velocity="0"/>
  </joint>

  <!-- J4: alpha=90, a=0,    d=380, offset=0   -->
  <joint name="joint4" type="revolute" offset_deg="0">
    <parent link="link3"/><child link="link4"/>
    <origin xyz="0 -380 0" rpy="90 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-200" upper="200" effort="0" velocity="0"/>
  </joint>

  <!-- J5: alpha=-90, a=0,   d=0,   offset=0   -->
  <joint name="joint5" type="revolute" offset_deg="0">
    <parent link="link4"/><child link="link5"/>
    <origin xyz="0 0 0" rpy="-90 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-115" upper="115" effort="0" velocity="0"/>
  </joint>

  <!-- J6: alpha=90,  a=0,   d=0,   offset=0   -->
  <joint name="joint6" type="revolute" offset_deg="0">
    <parent link="link5"/><child link="link6"/>
    <origin xyz="0 0 0" rpy="90 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-400" upper="400" effort="0" velocity="0"/>
  </joint>

  <!-- ToolMount: pos=0,0,65 relative to joint6 -->
  <joint name="tool_mount" type="fixed">
    <parent link="link6"/><child link="tool_mount"/>
    <origin xyz="0 0 65" rpy="0 0 0"/>
  </joint>

</robot>
